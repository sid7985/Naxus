{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NEXUS",
  "version": "1.0.0",
  "identifier": "com.nexus.ai.os",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NEXUS",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "bin/nexus-python"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "http": {
      "all": true,
      "request": true,
      "scope": [
        "http://localhost:1421/*",
        "http://127.0.0.1:1421/*"
      ]
    }
  }
}

